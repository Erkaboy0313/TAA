# TAA — environment variables (E00-S01 + E00-S02 scope).
# Copy to .env; never commit .env. Additional vars land in later stories
# (E02 Gemini/embeddings, E05 Telegram, etc.).

# Core Django
DEBUG=True
SECRET_KEY=change-me-in-real-env-please
ALLOWED_HOSTS=localhost,127.0.0.1

# Admin is gated by this flag; defaults to DEBUG. Prod stays False.
# In prod, prefer the IP-allowlist middleware (Faza 3) over turning this on.
ADMIN_ENABLED=False

# Database (Postgres 16 + pgvector in prod; SQLite acceptable only for
# throwaway smoke tests). When running via docker compose, the hostname is
# the compose service name `postgres`.
# Format: postgres://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgres://taa:taa_dev_password@postgres:5432/taa

# Docker compose Postgres service credentials — consumed by the `postgres`
# service in docker-compose.yml. Keep these in sync with DATABASE_URL above.
POSTGRES_USER=taa
POSTGRES_PASSWORD=taa_dev_password
POSTGRES_DB=taa

# Celery broker + result backend (E00-S02). Hostname `redis` = compose
# service name; swap for managed Redis URL in prod.
REDIS_URL=redis://redis:6379/0

# Locale (project-context R8 — Asia/Tashkent display, USE_TZ=True in settings).
TIME_ZONE=Asia/Tashkent
LANGUAGE_CODE=uz

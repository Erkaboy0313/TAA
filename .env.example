# TAA — environment variables (E00-S01 scope).
# Copy to .env; never commit .env. Additional vars land in later stories
# (E00-S02 Docker/Redis, E02 Gemini/embeddings, E05 Telegram, etc.).

# Core Django
DEBUG=True
SECRET_KEY=change-me-in-real-env-please
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (Postgres 16 in prod; SQLite acceptable for local smoke test only).
# Format: postgres://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgres://taa:taa@localhost:5432/taa

# Locale (project-context R8 — Asia/Tashkent display, USE_TZ=True in settings).
TIME_ZONE=Asia/Tashkent
LANGUAGE_CODE=uz
